  "keyFeatures": [
    "JWT-based authentication with configurable token expiration",
    "Full CRUD operations for purchase (Compra) management",
    "Clean Architecture with Domain, Application, Infrastructure, and API layers",
    "Angular Material UI with sortable, paginated data tables",
    "PDF and Excel export using jsPDF and XLSX libraries",
    "Unit of Work and Repository patterns for data access",
    "SQL Server database via Entity Framework Core",
    "CORS-configured API with Swagger/OpenAPI documentation",
    "Route guards and HTTP interceptors for secure navigation",
    "External logging via Azure-hosted logger API"
  ],
  "publicApiSurface": [
    "POST /Api/Users/ValidateUser",
    "POST /Api/Purchase/Save",
    "GET /Api/Purchase/List",
    "GET /Api/Purchase/Detail/{id}",
    "PUT /Api/Purchase/Update",
    "DELETE /Api/Purchase/Delete/{id}"
  ]
